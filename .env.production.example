# =============================================================================
# StickerApp frontend — production env template
#
# Copy to `.env.production` on the build machine (Sebastian's laptop) and
# fill in the placeholders. Vite bakes these in at `npm run build` time, so
# the resulting dist/ already carries the values. The publishable Stripe key
# is meant to be public; nothing here is a secret.
#
# .env.production is gitignored — never commit a real one.
# =============================================================================

VITE_API_BASE_URL=https://stickerapp.example.com/api/v1
VITE_FRONTEND_URL=https://stickerapp.example.com

# Stripe publishable key. Test key on day 1 (pk_test_...); swap to live key
# (pk_live_...) when the shop owner finishes Stripe onboarding, then rebuild
# and redeploy the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
