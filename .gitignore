# Node
node_modules/
.npm
.pnp
.pnp.js

# Vite / build output
dist/
dist-ssr/
*.local

# vue-tsc emit artifacts for root-level config files (tsconfig.node.json's
# composite mode would otherwise emit these next to their .ts source).
/vite.config.{js,d.ts}
/tailwind.config.{js,d.ts}
/playwright.config.{js,d.ts}

# Env (never commit real secrets)
.env
.env.local
.env.production
.env.*.local
!.env.example

# Playwright
test-results/
playwright-report/
playwright/.cache/

# IDE
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
