# Backend API base — points at the Django backend (EnDosStudioApp).
# In dev, the Django backend runs on :8000. The /api/v1 prefix is part of the
# backend's URL convention; see the backend repo for the full endpoint surface.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# This frontend's own URL — used in flows where the backend redirects back here
# (e.g. password-reset email links land at {VITE_FRONTEND_URL}/reset-password).
VITE_FRONTEND_URL=http://localhost:5173

# Stripe publishable key (test keys for dev — never put secret keys here).
# Real keys land at deploy time when the shop owner's Stripe account is set up.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
